# Linear API Configuration
# Copy this file to .env.local and fill in your credentials
# .env.local should NOT be committed to git

# Your Linear API key (get it from https://linear.app/settings/api)
LINEAR_API_KEY=your_api_key_here

# Your Linear team ID (get it from a ticket URL: https://linear.app/team-id/issue/...)
LINEAR_TEAM_ID=your_team_id_here

# Your Linear workspace ID (optional, for workspace-level operations)
LINEAR_WORKSPACE_ID=your_workspace_id_here

# Current issue ID (optional, can be set per session)
LINEAR_ISSUE_ID=UI-123
