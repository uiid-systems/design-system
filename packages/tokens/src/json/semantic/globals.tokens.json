{
  "$description": "UIID Design System - Global Tokens",
  "$schema": "../../../dtcg.schema.json",
  "globals": {
    "header": {
      "height": { "$value": "3.5rem", "$type": "dimension" }
    },
    "transition": {
      "duration-fast": { "$value": "100ms", "$type": "duration" },
      "duration": { "$value": "150ms", "$type": "duration" },
      "duration-slow": { "$value": "300ms", "$type": "duration" },
      "easing": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "string" },
      "easing-spring": { "$value": "cubic-bezier(0.85, 0, 0.15, 1)", "$type": "string" }
    },
    "transform": {
      "origin": { "$value": "center", "$type": "string" },
      "scale-down": { "$value": 0.9, "$type": "number" },
      "scale-up": { "$value": 1.1, "$type": "number" }
    },
    "shadow": {
      "$type": "shadow",
      "xs": {
        "$value": {
          "color": "#0000000a",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "0px"
        }
      },
      "sm": {
        "$value": {
          "color": "#00000013",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "3px",
          "spread": "0px"
        }
      },
      "md": {
        "$value": [
          {
            "color": "#0000001a",
            "offsetX": "0px",
            "offsetY": "4px",
            "blur": "6px",
            "spread": "-1px"
          },
          {
            "color": "#0000000d",
            "offsetX": "0px",
            "offsetY": "2px",
            "blur": "4px",
            "spread": "-2px"
          }
        ]
      },
      "lg": {
        "$value": [
          {
            "color": "#0000001a",
            "offsetX": "0px",
            "offsetY": "10px",
            "blur": "15px",
            "spread": "-3px"
          },
          {
            "color": "#0000000d",
            "offsetX": "0px",
            "offsetY": "4px",
            "blur": "6px",
            "spread": "-4px"
          }
        ]
      }
    },
    "disabled": {
      "opacity": { "$value": 0.5, "$type": "number" }
    },
    "icon": {
      "size": { "$value": "0.875rem", "$type": "dimension" }
    },
    "z-index": {
      "modal": { "$value": 3, "$type": "number" }
    },
    "border": {
      "color": { "$value": "{shade.accent}", "$type": "color" },
      "radius": { "$value": "0.5rem", "$type": "dimension" },
      "width": { "$value": "1px", "$type": "dimension" }
    },
    "padding": {
      "x": { "$value": "1rem", "$type": "dimension" },
      "y": { "$value": "1rem", "$type": "dimension" }
    },
    "outline": {
      "color": { "$value": "{shade.foreground}", "$type": "color" },
      "offset": { "$value": "0.125rem", "$type": "dimension" },
      "style": { "$value": "solid", "$type": "strokeStyle" },
      "width": { "$value": "0.125rem", "$type": "dimension" }
    },
    "placeholder": {
      "color": { "$value": "{shade.muted}", "$type": "color" }
    }
  }
}
