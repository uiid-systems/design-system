{
  "name": "@uiid/design-system",
  "version": "0.0.18",
  "description": "UIID Design System — all components in a single package",
  "license": "MIT",
  "author": "Adam Fratino",
  "repository": {
    "type": "git",
    "url": "https://github.com/uiid-systems/design-system",
    "directory": "packages/design-system"
  },
  "homepage": "https://github.com/uiid-systems/design-system/tree/main/packages/design-system",
  "bugs": "https://github.com/uiid-systems/design-system/issues",
  "keywords": [
    "uiid",
    "react",
    "components",
    "design-system"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./globals.css": "./dist/design-system.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@uiid/buttons": "workspace:*",
    "@uiid/calendars": "workspace:*",
    "@uiid/cards": "workspace:*",
    "@uiid/code": "workspace:*",
    "@uiid/forms": "workspace:*",
    "@uiid/icons": "workspace:*",
    "@uiid/indicators": "workspace:*",
    "@uiid/interactive": "workspace:*",
    "@uiid/layout": "workspace:*",
    "@uiid/lists": "workspace:*",
    "@uiid/navigation": "workspace:*",
    "@uiid/overlays": "workspace:*",
    "@uiid/tables": "workspace:*",
    "@uiid/tokens": "workspace:*",
    "@uiid/typography": "workspace:*",
    "@uiid/utils": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.3.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
